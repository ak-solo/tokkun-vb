# デフォルト: テキストファイルはリポジトリ内を LF に正規化し、
# Windows チェックアウト時に CRLF へ変換する
* text=auto

# ソースコード・設定ファイル — 常に LF
*.vb        text eol=lf
*.vbproj    text eol=lf
*.sln       text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.config    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.ipynb     text eol=lf
Dockerfile  text eol=lf
*.sh        text eol=lf

# バイナリファイル — 改行変換しない
*.dll       binary
*.exe       binary
*.pdb       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.nupkg     binary
