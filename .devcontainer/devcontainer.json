{
  "name": "tokkun-vb",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "dotnet restore",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.vscode-dotnet-runtime",
        "ms-dotnettools.vscode-dotnet-pack",
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolution": "tokkun-vb.sln",
        "dotnetAcquisitionExtension.existingSdkPath": "/usr/share/dotnet"
      }
    }
  }
}
